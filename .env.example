# Option 1: Personal access token (simple, single-user)
DISCOGS_TOKEN=your_personal_access_token_here

# Option 2: OAuth 1.0a (multi-user, enables "Connect to Discogs" flow)
DISCOGS_CONSUMER_KEY=your_consumer_key_here
DISCOGS_CONSUMER_SECRET=your_consumer_secret_here

# Required when running in Docker (container hostname isn't reachable by browser)
OAUTH_CALLBACK_URL=http://localhost:8000/api/auth/callback

OPENROUTER_API_KEY=your_openrouter_api_key_here
