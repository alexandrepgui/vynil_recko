# ── Supabase Auth ─────────────────────────────────────────────────────────
# Local dev (supabase CLI): values from `npx supabase status`
SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=<anon key from `npx supabase status`>
# Production: replace with your Supabase Cloud project values

# ── Discogs ───────────────────────────────────────────────────────────────
# Personal access token (fallback when user has no OAuth connection)
DISCOGS_TOKEN=your_personal_access_token_here

# OAuth 1.0a (enables "Connect to Discogs" flow per user)
DISCOGS_CONSUMER_KEY=your_consumer_key_here
DISCOGS_CONSUMER_SECRET=your_consumer_secret_here

# Required when running in Docker (container hostname isn't reachable by browser)
OAUTH_CALLBACK_URL=http://localhost:8000/api/discogs/callback

# ── LLM ───────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LLM provider: "openrouter" (default) or "google"
LLM_PROVIDER=openrouter

# Required only if LLM_PROVIDER=google
GOOGLE_AI_API_KEY=your_google_ai_api_key_here
